{
  "name": "codex-provider-switch",
  "version": "1.0.0",
  "description": "Electron desktop app for switching Codex provider presets and editing ~/.codex credentials.",
  "author": "Administrator",
  "license": "MIT",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "build": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.codex.providerswitch",
    "productName": "Codex Provider Switch",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  },
  "dependencies": {
    "@iarna/toml": "2.2.5"
  },
  "devDependencies": {
    "electron": "41.1.0",
    "electron-builder": "26.8.1"
  }
}
